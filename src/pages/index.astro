---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../consts";
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main>
      <h1>Welcome to Currently!</h1>
      <p>
        Currently: app is a state of mind journal. It's a place to write down
        your thoughts and feelings, and to reflect on your life. Currently on
        iOS only.
      </p>
    </main>
    <Footer />
  </body>
</html>
